        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import java.text.SimpleDateFormat
import java.util.Calendar

//def sdf = new SimpleDateFormat(&quot;MM/dd/yyyy&quot;)
//def cal = Calendar.getInstance()

// ================= WEEKLY =================
// ================= WEEKLY (FIXED) =================
def sdf = new java.text.SimpleDateFormat(&quot;MM/dd/yyyy&quot;)
def cal = Calendar.getInstance()

cal.setFirstDayOfWeek(Calendar.MONDAY)

int day = cal.get(Calendar.DAY_OF_WEEK)
int diff = day - Calendar.MONDAY

if (diff &lt; 0) {
    diff += 7
}

// Move to Monday of current week
cal.add(Calendar.DAY_OF_MONTH, -diff)
def weekStart = cal.getTime()

// Move to Sunday
cal.add(Calendar.DAY_OF_MONTH, 6)
def weekEnd = cal.getTime()

vars.put(&quot;weekFromDate&quot;, sdf.format(weekStart))
vars.put(&quot;weekToDate&quot;, sdf.format(weekEnd))

// ================= MONTHLY =================
def monthStart = cal.clone()
monthStart.set(Calendar.DAY_OF_MONTH, 1)

def monthEnd = cal.clone()
monthEnd.set(Calendar.DAY_OF_MONTH, cal.getActualMaximum(Calendar.DAY_OF_MONTH))

vars.put(&quot;monthFromDate&quot;, sdf.format(monthStart.getTime()))
vars.put(&quot;monthToDate&quot;, sdf.format(monthEnd.getTime()))

// ================= YEARLY =================
def yearStart = cal.clone()
yearStart.set(Calendar.MONTH, Calendar.JANUARY)
yearStart.set(Calendar.DAY_OF_MONTH, 1)

def yearEnd = cal.clone()
yearEnd.set(Calendar.MONTH, Calendar.DECEMBER)
yearEnd.set(Calendar.DAY_OF_MONTH, 31)

vars.put(&quot;yearFromDate&quot;, sdf.format(yearStart.getTime()))
vars.put(&quot;yearToDate&quot;, sdf.format(yearEnd.getTime()))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
